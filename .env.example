# ── Option 1: Google Gemini (FREE) — get key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza-YOUR_KEY_HERE
# Optional: add extra Gemini keys (different Google accounts) for automatic quota fallback
# GEMINI_API_KEY_2=AIza-YOUR_SECOND_KEY_HERE
# GEMINI_API_KEY_3=AIza-YOUR_THIRD_KEY_HERE

# ── Option 2: xAI Grok — https://console.x.ai
# XAI_API_KEY=xai-YOUR_KEY_HERE

# ── Option 3: Anthropic Claude — https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# Optional — API server port (default 3001, auto-increments if busy)
# PORT=3001
